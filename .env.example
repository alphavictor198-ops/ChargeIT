# GatiCharge Environment Variables
# Copy this file to .env and fill in your real values

# ─── Application ─────────────────────────────────────────────
APP_NAME=GatiCharge
DEBUG=false
ENVIRONMENT=production

# ─── Database ────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://gaticharge:gaticharge_secure_pass_2025@localhost:5432/gaticharge

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Authentication ──────────────────────────────────────────
# IMPORTANT: Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_64_character_random_hex_string_for_production_use

# ─── Google OAuth (Optional) ────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── External APIs ───────────────────────────────────────────
# Google Maps / Directions API
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_KEY=

# OpenWeather API (for temperature-based range adjustment)
# Get from: https://openweathermap.org/api
OPENWEATHER_KEY=

# Open Charge Map API (for live station data across India)
# Get free key from: https://openchargemap.org/site/develop/api
OPENCHARGEMAP_KEY=

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── Security ────────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Rate limit: requests per period per IP
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
